<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.synfusion.pipelistpro.ui.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.synfusion.pipelistpro.ui.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_projectList"
            app:destination="@id/projectListFragment" />
    </fragment>

    <fragment
        android:id="@+id/addMaterialFragment"
        android:name="com.synfusion.pipelistpro.ui.AddMaterialFragment"
        android:label="Add Material"
        tools:layout="@layout/fragment_add_material">
        <action
            android:id="@+id/action_addMaterial_to_projectList"
            app:destination="@id/projectListFragment" />
    </fragment>

    <fragment
        android:id="@+id/projectListFragment"
        android:name="com.synfusion.pipelistpro.ui.ProjectListFragment"
        android:label="Project List"
        tools:layout="@layout/fragment_project_list">
        <action
            android:id="@+id/action_projectList_to_addMaterial"
            app:destination="@id/addMaterialFragment" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.synfusion.pipelistpro.ui.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

</navigation>
