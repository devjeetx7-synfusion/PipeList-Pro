<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.synfusion.pipelistpro.ui.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.synfusion.pipelistpro.ui.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_newProject"
            app:destination="@id/newProjectFragment" />
        <action
            android:id="@+id/action_home_to_savedProjects"
            app:destination="@id/savedProjectsFragment" />
        <action
            android:id="@+id/action_home_to_templates"
            app:destination="@id/templatesFragment" />
        <action
            android:id="@+id/action_home_to_materialSearch"
            app:destination="@id/materialSearchFragment" />
        <action
            android:id="@+id/action_home_to_settings"
            app:destination="@id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/newProjectFragment"
        android:name="com.synfusion.pipelistpro.ui.NewProjectFragment"
        android:label="New Project"
        tools:layout="@layout/fragment_new_project">
        <action
            android:id="@+id/action_newProject_to_materialSearch"
            app:destination="@id/materialSearchFragment" />
    </fragment>

    <fragment
        android:id="@+id/savedProjectsFragment"
        android:name="com.synfusion.pipelistpro.ui.SavedProjectsFragment"
        android:label="Saved Projects"
        tools:layout="@layout/fragment_saved_projects">
        <action
            android:id="@+id/action_savedProjects_to_projectList"
            app:destination="@id/projectListFragment" />
    </fragment>

    <fragment
        android:id="@+id/templatesFragment"
        android:name="com.synfusion.pipelistpro.ui.TemplatesFragment"
        android:label="Templates"
        tools:layout="@layout/fragment_templates">
        <action
            android:id="@+id/action_templates_to_projectList"
            app:destination="@id/projectListFragment" />
    </fragment>

    <fragment
        android:id="@+id/materialSearchFragment"
        android:name="com.synfusion.pipelistpro.ui.MaterialSearchFragment"
        android:label="Material Search"
        tools:layout="@layout/fragment_material_search">
        <action
            android:id="@+id/action_materialSearch_to_addMaterial"
            app:destination="@id/addMaterialFragment" />
    </fragment>

    <fragment
        android:id="@+id/addMaterialFragment"
        android:name="com.synfusion.pipelistpro.ui.AddMaterialFragment"
        android:label="Add Material"
        tools:layout="@layout/fragment_add_material">
        <action
            android:id="@+id/action_addMaterial_to_projectList"
            app:destination="@id/projectListFragment"
            app:popUpTo="@id/materialSearchFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/projectListFragment"
        android:name="com.synfusion.pipelistpro.ui.ProjectListFragment"
        android:label="Project List"
        tools:layout="@layout/fragment_project_list">
        <action
            android:id="@+id/action_projectList_to_materialSearch"
            app:destination="@id/materialSearchFragment" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.synfusion.pipelistpro.ui.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

</navigation>
